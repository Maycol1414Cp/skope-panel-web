{
  "expo": {
    "name": "skope",
    "slug": "skope",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "skope",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.anonymous.skope",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.skope"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-status-bar",
      "@maplibre/maplibre-react-native",
      "expo-font",
      "@react-native-vector-icons/material-icons",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Skope usa tu ubicación para mostrarte reportes cercanos y validar la confiabilidad de los que hagas."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Skope necesita acceso a tus fotos para adjuntar evidencia a un reporte."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#004AC6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ece8ec72-0750-47ea-9685-db796cf9a743"
      }
    }
  }
}
